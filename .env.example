# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Paste the entire JSON content of your Google service account key file here,
# on a single line (minify it at https://jsonformatter.org/json-minifier)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# The Google Drive folder ID — found in the folder's share URL:
# https://drive.google.com/drive/folders/THIS_PART_HERE
DRIVE_FOLDER_ID=your_folder_id_here

# The Google Sheet ID — found in the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SHEETS_ID=your_sheet_id_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-github-pages-url.github.io,http://localhost:8080
